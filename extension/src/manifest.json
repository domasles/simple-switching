{
    "{{chrome}}.manifest_version": 3,
    "{{firefox}}.manifest_version": 2,

    "icons": {
        "16": "icon/16.png",
        "32": "icon/32.png",
        "48": "icon/48.png",
        "96": "icon/96.png",
        "128": "icon/128.png"
    },

    "background": {
        "{{chrome}}.service_worker": "src/background.ts",
        "{{firefox}}.scripts": ["src/background.ts"]
    },

    "permissions": ["storage"],

    "commands": {
        "switch-tab-fwd": {
            "description": "Cycle recent tabs forward",
            "suggested_key": { "default": "Alt+Q" }
        },

        "switch-tab-back" : {
            "description": "Cycle recent tabs backward",
            "suggested_key": { "default": "Alt+Shift+Q" }
        }
    }
}
